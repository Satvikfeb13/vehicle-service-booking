{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "server=YOUR_SERVER;database=YOUR_DATABASE;user=YOUR_USERNAME;password=YOUR_PASSWORD;"
  },

  "AppSettings": {
    "DefaultMechanicPassword": "YourDefaultPassword123!"
  },

  "Jwt": {
    "Key": "YourSuperSecretJwtKeyThatShouldBeAtLeast32CharactersLong",
    "Issuer": "YourApplicationName",
    "Audience": "YourApplicationClients"
  },

  "AllowedHosts": "*"
}
